# Environment variables for JioSaavn API

# Node Environment (development or production)
NODE_ENV=development

# Server Port (Vercel will override this to 80 in production)
PORT=3000

# Rate Limiting (enable or disable request rate limiting)
# Set to 'true' to enable rate limiting (optional)
# ENABLE_RATE_LIMIT=false

# Log Level (debug, info, warn, error)
# LOG_LEVEL=debug
