# Vercel Ignore File
# Files and folders to exclude from Vercel deployment

# Documentation
docs/
*.md

# Development files
.eslintrc
.prettierrc
.gitignore
.git
.github

# Node modules (Vercel installs these)
node_modules/

# Environment
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Build artifacts
dist/
build/
public/

# Test
.test
.spec
coverage/
__tests__/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Misc
tmp/
temp/
.cache/

# Keep these files!
# ! src/
# ! api/
# ! package.json
# ! tsconfig.json
# ! vercel.json
